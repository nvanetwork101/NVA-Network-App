rules_version = '2';

// =====================================================================
// ==================== SERVICE: CLOUD FIRESTORE =======================
// =====================================================================
service cloud.firestore {
  match /databases/{database}/documents {

    // --- SECURE, ZERO-COST SYSTEM HIERARCHY HELPERS (Exempt from 10-Get limit) ---
    function isAuthenticated() { return request.auth != null; }
    function isSuperAdmin() { return isAuthenticated() && request.auth.token.super_admin == true; }
    function isAdmin() { return isAuthenticated() && (request.auth.token.admin == true || isSuperAdmin()); }
    function isModerator() { return isAuthenticated() && (request.auth.token.authority == true || request.auth.token.moderator == true || isAdmin()); }

    match /eventComments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.userId || isModerator());
      allow update: if false;
    }

    // --- COLLECTIONS ---

    match /creators/{userId} {
      allow list: if true;
      allow get: if (request.auth.uid == userId) ||
                     (isAuthenticated() &&
                       !exists(/databases/$(database)/documents/creators/$(request.auth.uid)/blockedUsers/$(userId)) &&
                       !exists(/databases/$(database)/documents/creators/$(userId)/blockedBy/$(request.auth.uid))
                     );

      allow create: if request.auth.uid == userId;

      allow update: if
        isModerator() ||
        (
          request.auth.uid == userId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            // Standard cosmetic fields allowed for client-side writes [1]
            'creatorName', 'realName', 'dateOfBirth', 'age', 'bio', 'categories', 'creatorField', 'role', 'existingWorkLink', 'profilePictureUrl',
            'featuredVideoLink', 'pinnedContent', 'updatedAt', 'lastLoginTimestamp', 'location', 'lastSubmissionTimestamp', 'lastCommentTimestamp',
            'followingCount', 'blockedUsers', 'blockedBy', 'studioGallery',
            'currentChallengeLink', 'currentChallengeThumbnail', 'teamTag',
            'competitionStatus', 'isEliminated', 'isContestant',
            'isLive', 'liveRoomType', 'latestNotification', 'heroProduct', 'arenaTokens'
          ]) &&
          (
            (request.resource.data.get('role', 'user') == resource.data.get('role', 'user')) ||
            (
              resource.data.get('role', 'user') != 'super_admin' &&
              resource.data.get('role', 'user') != 'admin' &&
              resource.data.get('role', 'user') != 'authority' &&
              resource.data.get('role', 'user') != 'moderator' &&
              (request.resource.data.role == 'creator' || request.resource.data.role == 'user')
            )
          )
        ) ||
        (
          request.auth.uid != userId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followerCount', 'followingCount']) &&
          (
            (request.resource.data.get('followerCount', 0) == resource.data.get('followerCount', 0) + 1 || request.resource.data.get('followerCount', 0) == resource.data.get('followerCount', 0) - 1) ||
            (request.resource.data.get('followingCount', 0) == resource.data.get('followingCount', 0) + 1 || request.resource.data.get('followingCount', 0) == resource.data.get('followingCount', 0) - 1)
          )
        ) ||
        (
          request.auth.uid != userId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['voteCount']) &&
          request.resource.data.voteCount == resource.data.get('voteCount', 0) + 1
        );

       allow delete: if false;

     match /followers/{followerId} {
        allow get: if isAuthenticated() && request.auth.uid == followerId;
        allow list: if isAuthenticated() && request.auth.uid == userId;
        allow write: if false; 
      }
      match /following/{followedUserId} {
        allow read: if isAuthenticated() && request.auth.uid == userId;
        allow write: if false; 
      }
      match /blockedUsers/{blockedId} {
        allow get: if isAuthenticated() && request.auth.uid == userId;
        allow list: if isAuthenticated() && request.auth.uid == userId;
        allow write: if isAuthenticated() && request.auth.uid == userId;
      }
      match /blockedBy/{blockerId} {
        allow read: if isAuthenticated() && request.auth.uid == userId; 
        allow write: if isAuthenticated() && request.auth.uid == blockerId;
      }
      match /savedOpportunities/{opportunityId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
      match /feed/{feedItemId} {
        allow read: if isAuthenticated() && request.auth.uid == userId;
        allow delete: if isAuthenticated() && request.auth.uid == userId;
        allow create, update: if false;
      }
      match /seenNotifications/{notificationId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }

    match /{path=**}/chatMessages/{messageId} {
       allow read: if isAuthenticated();
       allow create: if false;
       allow delete: if (isAuthenticated() && request.auth.uid == resource.data.userId) || isModerator();
    }

    match /follows/{followId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.followerId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.followerId == request.auth.uid;
      allow update: if false;
    }

    match /reports/{reportId} {
       allow create: if isAuthenticated() && request.resource.data.reporterId == request.auth.uid;
       allow read, list, update, delete: if isModerator();
    }

    match /payoutRequests/{requestId} {
        allow list: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
        allow get: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
        allow create: if false; // LOCKED: All creations now strictly flow through requestPayout Cloud Function
        allow update, delete: if isAdmin();
    }

    match /payoutHistory/{historyId} {
        allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.userId);
        allow write: if isAdmin();
    }

    match /appeals/{appealId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, list, update, delete: if isModerator();
    }

    match /events/{eventId}/chatMessages/{messageId} {
      allow read, write: if request.auth != null;
    }
    
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow update: if isAuthenticated() && request.auth.uid == resource.data.userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      allow create: if isAdmin();
      allow delete: if false;
    }

    match /broadcast_notifications/{notificationId} {
      allow read: if true;
      allow write: if false;
    }

    match /live_arena/{document} {
      allow read: if true;
      allow write: if isAuthenticated() && (
        isModerator() || 
        (get(/databases/$(database)/documents/creators/$(request.auth.uid)).data.get('role', 'user') in ['admin', 'authority', 'super_admin', 'moderator'])
      );
    }

    match /film_club_notices/{noticeId} {
      allow read: if isAuthenticated() && (
        get(/databases/$(database)/documents/creators/$(request.auth.uid)).data.get('isFilmClub', false) == true || 
        isModerator()
      );
      allow create, delete: if isModerator();
      allow update: if isModerator() || (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['acknowledgments']));
    }

    match /film_club_lounge/{msgId} {
      allow read, create: if isAuthenticated() && (
        get(/databases/$(database)/documents/creators/$(request.auth.uid)).data.get('isFilmClub', false) == true || 
        isModerator()
      );
      allow update: if isModerator();
      allow delete: if isModerator() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    match /filmClubWaitingList/{waitingId} {
      allow create: if isAuthenticated();
      allow read, write: if isModerator();
    }

    // =====================================================================
    // ============ RULES FOR AUTOMATED EVENT LIFECYCLE SYSTEM =============
    // =====================================================================
    match /events/{eventId} {
      allow read: if true;
      allow write: if isModerator();

      match /likes/{userId} {
          allow list: if isAuthenticated();
          allow get: if true;
          allow write: if false;
      }

      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow write: if false;
      }

      match /mutedUsers/{userId} {
        allow read: if isAuthenticated();
        allow write: if false;
      }
    }
    match /settings/currencyRates {
      allow read: if true;
    }

    // --- SUPER ADMIN SENSITIVE FINANCIAL BLOCKS ---
    match /settings/commissions {
      allow read, write: if isSuperAdmin();
    }

    match /settings/systemFinancials {
      allow read, write: if isSuperAdmin();
    }

    // THE FIX: Restrict the wildcard so it doesn't accidentally grant standard Admins access to Finance blocks
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin() && docId != 'commissions' && docId != 'systemFinancials'; 
    }

    match /contactSubmissions/{submissionId} {
      allow create: if isAuthenticated();
      allow read, list, update, delete: if isModerator();
    }

    match /statistics/{path=**} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /content_categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isModerator();
    }

    match /banRequests/{requestId} {
      allow create: if isModerator() && request.resource.data.requesterId == request.auth.uid;
      allow read, delete: if isAdmin();
      allow update: if false;
    }

    match /paymentPledges/{pledgeId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow list: if isAdmin() || 
                  (isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.targetUserId == request.auth.uid)) ||
                  (resource.data.status == 'approved' && resource.data.paymentType == 'giftToken');
      allow get: if isAdmin() || 
                 (isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.targetUserId == request.auth.uid)) ||
                 (resource.data.status == 'approved' && resource.data.paymentType == 'giftToken');
      allow update, delete: if isAdmin();
    }

    match /enrollmentApplications/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isModerator());
      allow write: if false;
    }

    match /movies/{movieId} {
      allow read: if true;
      allow create, update: if isAuthenticated() && isAdmin();
      allow delete: if isAuthenticated() && (isAdmin() || resource.data.creatorId == request.auth.uid);
    }
    
    match /movieReviews/{reviewId} {
      allow read: if true;
      allow create, update: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
    }
    
    match /discussions/{discussionId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isAuthenticated() && (resource.data.authorId == request.auth.uid || isModerator());
    }

    match /movieSuggestions/{suggestionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.suggestedBy == request.auth.uid;
      allow update, delete: if isAuthenticated() && (isAdmin() || isModerator());
    }

    match /promotedStatuses/{statusId} {
        allow list: if true;
        allow get: if (resource.data.status == 'approved_and_scheduled') ||
               (isAuthenticated() && request.auth.uid == resource.data.postedByUid) ||
               isModerator();
        allow write: if false;
    }

    match /opportunities/{opportunityId} {
      allow list: if true;
      allow get: if true;
      allow create: if false;
      allow update, delete: if isAuthenticated() && (request.auth.uid == resource.data.postedByUid || isModerator());

      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
        allow delete: if isAuthenticated() && (request.auth.uid == resource.data.userId || isModerator());
        allow update: if false;
      }
    }

    match /competitions/{competitionId} {
      allow list: if true;
      allow get: if resource.data.status != 'Pending' || isModerator();
      allow create, update, delete: if isAdmin();

      match /entries/{entryId} {
        allow read: if true;
        allow create, update: if false;
        allow delete: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());

        match /likes/{userId} {
          allow write: if isAuthenticated() && request.auth.uid == userId;
          allow read: if true;
        }
      }
    }

    match /chats/{chatId} {
      allow get: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow list: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isAuthenticated() && get(/databases/$(database)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]);
        allow write: if false;
      }
    }

    match /artifacts/{appId}/public/data/content_items/{contentId} {
      allow read: if true;
      allow create, delete: if (isAuthenticated() && (request.auth.uid == resource.data.creatorId || request.auth.uid == request.resource.data.creatorId)) || isModerator();
      allow update: if
        ((isAuthenticated() && (request.auth.uid == resource.data.creatorId || request.auth.uid == request.resource.data.creatorId)) || isModerator()) ||
        (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount']));

      match /likes/{userId} {
          allow list: if isAuthenticated();
          allow get: if true;
          allow write: if false;
      }

      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow write: if false;
      }
    }

    match /artifacts/{appId}/public/data/campaigns/{campaignId} {
        allow list: if true;
        allow get: if (resource.data.status == 'active') || (isAuthenticated() && resource.data.creatorId == request.auth.uid) || isModerator();
        allow create: if isAuthenticated() && request.resource.data.creatorId == request.auth.uid;
        allow update: if isModerator() || (isAuthenticated() && resource.data.creatorId == request.auth.uid);
        allow delete: if false;
    }

    // --- SUPER ADMIN EXCLUSIVE FINANCIAL LEDGERS ---
    match /transactions/{txnId} {
        allow read: if isSuperAdmin();
        allow write: if false; 
    }

    match /expenses/{expenseId} {
        allow read, write: if isSuperAdmin();
    }

    // --- BID WARS ENGINE (NEW) ---
    match /auctions/{auctionId} {
      allow read, list: if true;
      allow create: if isAuthenticated() && request.resource.data.sellerId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.sellerId == request.auth.uid || request.auth.uid == resource.data.highestBidderId);
      allow delete: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
    }

    match /financial_transactions/{txnId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid));
      allow write: if false; // Locked to Cloud Functions
    }

    // --- FILM CLUB REAL-TIME TYPING ---
    match /film_club_typing/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }
  } 
}